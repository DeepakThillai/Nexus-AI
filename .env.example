# ── Copy this file to .env and fill in your values ───────────────
# cp .env.example .env

# ── Groq API ──────────────────────────────────────────────────────
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── MongoDB Atlas ─────────────────────────────────────────────────
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/
MONGO_DB=career_navigation
MONGO_COLL=user_contexts

# ── CORS / Frontend URL ───────────────────────────────────────────
# For local Docker: http://localhost:3000
# For production:   https://yourdomain.com
FRONTEND_URL=http://localhost:3000

# ── Backend URL seen by the browser ──────────────────────────────
# For local Docker:      http://localhost:8000
# For production:        https://api.yourdomain.com
# NOTE: browser calls go to localhost:8000, not the Docker service name
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Optional ──────────────────────────────────────────────────────
LOG_LEVEL=INFO
